# Glint — environment configuration
# Copy to .env and fill in the values

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex())")
SECRET_KEY=change-me-generate-a-real-secret

# HIBP API Key (optional — required for email breach check)
# Get one at: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# AbuseIPDB API Key (optional — IP reputation check)
# Get one at: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# SQLite database path
DATABASE_PATH=glint.db

# Enable Flask debug mode (never set to true in production)
FLASK_DEBUG=false
